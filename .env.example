# Public base URL of the deployed site (no trailing slash).
# Used for canonical URLs, sitemap, robots, Open Graph, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Optional: Google Maps Embed API key. If set, property maps use the official
# Maps Embed API (best quality + ToS-compliant). If left blank, maps still work
# via the keyless google.com/maps embeds. Get a key at:
# https://console.cloud.google.com/  (enable "Maps Embed API")
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=
